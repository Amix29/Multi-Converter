# Optional cache headers for hosts that support _headers files, such as
# Cloudflare Pages and Netlify. GitHub Pages ignores this file.

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/site-interactions.js
  Cache-Control: public, max-age=31536000, immutable

/robots.txt
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600

/Multi-Converter/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/Multi-Converter/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

/Multi-Converter/*.svg
  Cache-Control: public, max-age=31536000, immutable

/Multi-Converter/*.png
  Cache-Control: public, max-age=31536000, immutable

/Multi-Converter/site-interactions.js
  Cache-Control: public, max-age=31536000, immutable

/Multi-Converter/robots.txt
  Cache-Control: public, max-age=3600

/Multi-Converter/sitemap.xml
  Cache-Control: public, max-age=3600
