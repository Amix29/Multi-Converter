{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": {
      "bundled-engines/": "engines/"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  }
}
