{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Multi-Converter",
  "version": "1.0.6",
  "identifier": "com.multiconverter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Multi-Converter",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 640,
        "backgroundColor": "#f6f4ef"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 https://api.github.com https://translate.googleapis.com; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyNjRDMTM3N0M1RDdDNjkKUldScGZGMThOOEZra2dUMWhIT0hGOG05WXR5SmE5dGVFYVJwa2FDZ3JIMGQ3dlZNZkFHa1JlcC8K",
      "endpoints": [
        "https://github.com/Amix29/Multi-Converter/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": {
      "bundled-engines/": "engines/"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp",
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "compression": "zlib",
        "startMenuFolder": "Multi-Converter",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
